  },
  "homepage": "https://github.com/hasham7861/fantastic-memory#readme",
  "dependencies": {
    "connect-mongodb-session": "^2.4.1",
    "cookie-parser": "^1.4.5",
    "cors": "^2.8.5",
    "express": "^4.17.1",
    "express-session": "^1.17.2",
    "mongoose": "5.11.15",
    "ramda": "^0.27.1",
    "socket.io": "^2.3.0"
  },
  "devDependencies": {
    "chai": "^4.3.0",
    "eslint": "^7.19.0",
